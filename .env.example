# Ethereum RPC Configuration
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY

# Wallet Configuration (CRITICAL: Never commit private keys!)
PRIVATE_KEY=your_private_key_here_without_0x_prefix
EXECUTOR_ADDRESS=0xYourExecutorAddress

# Flashbots / MEV Relays
FLASHBOTS_RELAY=https://relay.flashbots.net
BEAVER_RELAY=https://rpc.beaverbuild.org
TITAN_RELAY=https://rpc.titanbuilder.net
BUILDER069_RELAY=https://builder0x69.io

# CEX API Keys (for Delta Hedging)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret

# Bot Configuration
MIN_PROFIT_THRESHOLD=1000000000000000
MAX_GAS_PRICE=500000000000
TIP_PERCENTAGE=85
AUTOPILOT=false